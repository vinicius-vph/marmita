NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# bcrypt hash encoded in base64 — base64 avoids $ expansion by dotenv
# Generate with: node -e "require('bcryptjs').hash('your-password',12).then(h=>console.log(Buffer.from(h).toString('base64')))"
ADMIN_PASSWORD_HASH=base64encodedBcryptHashHere
AUTH_SECRET=random-32-characters-secret
# Dev only — comma-separated list of allowed origins (defaults to 127.0.0.1,localhost)
ALLOWED_DEV_ORIGINS=127.0.0.1,localhost
# Set to 'true' in CI/test environments to bypass rate limiting and avoid DB pollution
RATE_LIMIT_DISABLED=false
MBWAY_PHONE=+000123456789
WHATSAPP_PHONE=+000123456789
INSTAGRAM_URL=https://www.instagram.com/
FACEBOOK_URL=https://www.facebook.com/