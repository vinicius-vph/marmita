# Supabase — obter em: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Chave de serviço (NUNCA expor ao browser — só usada no servidor)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Senha de acesso à área de gestão (/admin)
ADMIN_PASSWORD=escolha-uma-senha-segura

# Segredo para assinar cookies JWT (gerar com: openssl rand -hex 32)
AUTH_SECRET=uma-string-aleatoria-de-pelo-menos-32-caracteres

# Número MBWay para pagamentos
MBWAY_PHONE=+351968326760
